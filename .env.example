# ============================================
# LearnSpark + AkashGuard Environment Variables
# ============================================
# Copy this to .env and fill in real values

# --- MEDIA PROVIDER TOGGLE ---
# Set to "minimax" for testing, "venice" for hackathon demo
MEDIA_PROVIDER=venice

# --- Venice AI (hackathon) ---
VENICE_API_KEY=venice-sk-your-key-here
VENICE_API_BASE=https://api.venice.ai/api/v1
VENICE_TTS_VOICE=af_heart
VENICE_IMAGE_MODEL=nano-banana-pro
VENICE_VISION_MODEL=qwen3-vl-235b-a22b
VENICE_CHAT_MODEL=zai-org-glm-4.7

# --- MiniMax (testing fallback) ---
MINIMAX_API_KEY=your-minimax-key
MINIMAX_API_BASE=https://api.minimax.io/v1
MINIMAX_TTS_VOICE=English_CaptivatingStoryteller

# --- AkashML ---
AKASHML_API_KEY=akml-your-key-here
AKASHML_BASE_URL=https://api.akashml.com/v1
AKASHML_REASONING_MODEL=deepseek-ai/DeepSeek-V3.2
AKASHML_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# --- Akash Console API ---
AKASH_CONSOLE_API_KEY=ac.sk.production.your-key-here
AKASH_CONSOLE_API_BASE=https://console-api.akash.network/v1

# --- Docker Hub ---
DOCKER_HUB_USERNAME=xploitkid

# --- Telegram Bot (AkashGuard alerts) ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Langfuse Tracing ---
LANGFUSE_PUBLIC_KEY=your-key
LANGFUSE_SECRET_KEY=your-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- App Config ---
LEARNSPARK_PORT=8000
DEFAULT_DIFFICULTY=kid
DB_PATH=./data/akashguard.db
HEALTH_CHECK_INTERVAL=30
FAILURE_THRESHOLD=3
RESPONSE_TIME_THRESHOLD_MS=5000
